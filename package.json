{
  "name": "rubik-cube-algorithms",
  "version": "0.6.0",
  "private": true,
  "description": "This plugin visualizes Rubik Cube algorithms for Obsidian (https://obsidian.md)",
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "license": "MIT",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "format:json": "sort-package-json package.json",
    "lint": "eslint .",
    "lint:css": "stylelint \"styles.css\"",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "dependencies": {
    "@Altarok/obsidian-dev-utils": "github:Altarok/obsidian-dev-utils#main"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "jiti": "2.7.0",
    "obsidian": "1.12.3",
    "sort-package-json": "^4.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "allowScripts": {
    "esbuild": true
  }
}
