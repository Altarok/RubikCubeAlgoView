{
  "name": "rubik-cube-algorithms",
  "version": "0.5.1",
  "description": "This plugin visualizes Rubik Cube algorithms for Obsidian (https://obsidian.md)",
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "license": "MIT",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "format:json": "sort-package-json package.json",
    "lint": "eslint .",
    "lint:css": "stylelint \"styles.css\"",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "@Altarok/obsidian-dev-utils": "github:Altarok/obsidian-dev-utils#main",
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "latest",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "obsidian": "1.12.3",
    "sort-package-json": "^4.0.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
