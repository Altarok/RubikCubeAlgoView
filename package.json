{
  "name": "rubik-cube-algorithms",
  "version": "0.4.3",
  "description": "This plugin visualizes Rubik Cube algorithms for Obsidian (https://obsidian.md)",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "lint:css": "stylelint \"styles.css\""
  },
  "keywords": [],
  "license": "0-BSD",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "obsidian": "^1.13.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "allowScripts": {
    "esbuild@0.25.5": true,
    "esbuild@0.27.3": true
  }
}
